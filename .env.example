# ------------------------------------------------------------
# MITAN — Environment variables
# Copy to .env and fill in real values. Never commit .env.
# ------------------------------------------------------------

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/mitan?schema=public"

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Transactional email (Resend) — integration prepared, not required to boot
RESEND_API_KEY=""

# Media uploads (Cloudinary) — integration prepared, not required to boot
CLOUDINARY_URL=""

# Public base URL of the app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
